# ── 部署 ─────────────────────────────────────────────────
# GitHub Pages 子路径前缀；本地开发留空，CI 构建注入 /AI-Search
# NEXT_PUBLIC_BASE_PATH=/AI-Search

# ── 数据源 ───────────────────────────────────────────────
# DATA_SOURCE: auto | local | mock
#   auto  (默认) 本地快照(新鲜) -> mock 回退
#   local       强制使用 data/items.json 本地快照（构建静态站点用这个）
#   mock        强制使用内置示例数据（离线开发/演示）
DATA_SOURCE=auto

# auto 模式下，快照超过该小时数视为过期；0 表示不过期
STORE_MAX_AGE_HOURS=168

# ── 爬虫（npm run crawl）─────────────────────────────────
# GitHub Search 匿名 60 次/小时已够用；填 token 可提额并更稳定
# GITHUB_TOKEN=ghp_xxx
# GitHub 抓取的话题（逗号分隔）、时间窗（天）、每话题条数
GITHUB_TOPICS=llm,ai-agent,generative-ai,rag,llmops,agents,diffusion-models,multimodal
CRAWL_DAYS=30
GITHUB_PER_TOPIC=10
# 每个 RSS 源最多抓取条数
RSS_MAX_PER_FEED=20
# Hacker News 收录的最低点数
HN_MIN_POINTS=40
# 单次请求超时（毫秒）
CRAWL_TIMEOUT_MS=15000
# 是否抓取 arXiv（限流，默认关；置 1 开启，CI 默认开启）
# CRAWL_ARXIV=1
